#!/bin/bash

# Get list of staged TypeScript/JavaScript files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|js|tsx|jsx|mts|cts)$')

if [ -z "$STAGED_FILES" ]; then
  # No TypeScript/JavaScript files staged, exit successfully
  exit 0
fi

echo "Running Prettier and Oxlint on staged files..."

# Run Prettier to format files
echo "$STAGED_FILES" | xargs bunx prettier --write --ignore-unknown
PRETTIER_EXIT=$?

# Re-add formatted files to staging so the formatted versions are committed
if [ $PRETTIER_EXIT -eq 0 ]; then
  echo "$STAGED_FILES" | xargs git add
fi

# Run Oxlint on staged root files, leaving functions/ on its separate lint setup
ROOT_STAGED_FILES=$(echo "$STAGED_FILES" | grep -v '^functions/' || true)
if [ -n "$ROOT_STAGED_FILES" ]; then
  echo "$ROOT_STAGED_FILES" | xargs bunx oxlint
  OXLINT_EXIT=$?
else
  OXLINT_EXIT=0
fi

# Exit with error if either tool failed
if [ $PRETTIER_EXIT -ne 0 ] || [ $OXLINT_EXIT -ne 0 ]; then
  echo ""
  echo "❌ Pre-commit checks failed!"
  echo "Fix the issues above and try again."
  echo ""
  echo "To format files: bun run format"
  echo "To run root lint: bun run lint"
  echo "To apply targeted safe fixes: bunx oxlint --fix <paths>"
  exit 1
fi

echo "✅ Pre-commit checks passed!"
exit 0
