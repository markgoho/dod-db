#!/bin/bash

PRETTIER_EXIT=0
OXFMT_EXIT=0
OXLINT_EXIT=0
HAS_FORMAT_TARGETS=false

run_with_paths() {
  local command=("$@")
  shift $#
}

while IFS= read -r -d '' staged_file; do
  case "$staged_file" in
    hugo/layouts/shortcodes/*.html)
      ;;
    hugo/*.html|hugo/**/*.html)
      HAS_FORMAT_TARGETS=true
      bunx prettier --write "$staged_file" || PRETTIER_EXIT=$?
      if [ $PRETTIER_EXIT -eq 0 ]; then
        git add "$staged_file"
      fi
      ;;
    *.ts|*.js|*.tsx|*.jsx|*.mts|*.cts|*.json|*.md|*.css|*.scss|*.yml|*.yaml)
      HAS_FORMAT_TARGETS=true
      bunx oxfmt "$staged_file" || OXFMT_EXIT=$?
      if [ $OXFMT_EXIT -eq 0 ]; then
        git add "$staged_file"
      fi
      if [[ "$staged_file" != functions/* ]] && [[ "$staged_file" =~ \.(ts|js|tsx|jsx|mts|cts)$ ]]; then
        bunx oxlint "$staged_file" || OXLINT_EXIT=$?
      fi
      ;;
    *)
      ;;
  esac
done < <(git diff --cached --name-only --diff-filter=ACM -z)

if [ "$HAS_FORMAT_TARGETS" = false ] && [ $OXLINT_EXIT -eq 0 ]; then
  exit 0
fi

echo "Running oxfmt, Prettier, and Oxlint on staged files..."

if [ $PRETTIER_EXIT -ne 0 ] || [ $OXFMT_EXIT -ne 0 ] || [ $OXLINT_EXIT -ne 0 ]; then
  echo ""
  echo "❌ Pre-commit checks failed!"
  echo "Fix the issues above and try again."
  echo ""
  echo "To format files: bun run format"
  echo "To run root lint: bun run lint"
  echo "To apply targeted safe fixes: bunx oxlint --fix <paths>"
  exit 1
fi

echo "✅ Pre-commit checks passed!"
exit 0
