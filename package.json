    "prettier": "^3.8.0",
    "prettier-plugin-go-template": "^0.0.15",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typescript-eslint": "^8.53.0"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@google/genai": "^1.37.0",
    "assemblyai": "^4.22.1",
    "firebase-admin": "^13.6.0",
