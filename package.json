{
  "name": "dod-db",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "emulators:start": "firebase emulators:start --only auth,firestore",
    "tools": "bash src/scripts/start-tools.sh",
    "tools:api": "bun run src/scripts/tools-server.ts",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write . --ignore-unknown",
    "check": "bun run typecheck && bun run lint && bun run format",
    "generate:tag-index": "bun run src/scripts/generate-tag-episode-index.ts",
    "generate:book-index": "bun run src/scripts/generate-book-episode-index.ts",
    "topic-page:gather": "bun run src/scripts/gather-topic-context.ts",
    "topic-page:save": "bun run src/scripts/save-topic-page.ts",
    "topic-page:move": "bun run src/scripts/move-topic-page.ts",
    "book-page:gather": "bun run src/scripts/gather-book-context.ts",
    "book-page:save": "bun run src/scripts/save-book-page.ts",
    "guest-page:gather": "bun run src/scripts/gather-guest-page.ts",
    "guest-page:save": "bun run src/scripts/save-guest-page.ts",
    "hugo:dev": "bun run generate:tag-index && bun run generate:book-index && cd hugo && hugo server",
    "build:local": "bun run generate:tag-index && bun run generate:book-index && rm -rf hugo/public && cd hugo && hugo && bun run index",
    "index": "bunx pagefind --site hugo/public",
    "build:hugo": "bun run generate:tag-index && bun run generate:book-index && cd hugo && hugo --minify && bun run index"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/bun": "latest",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-unicorn": "^62.0.0",
    "firebase-tools": "^15.15.0",
    "globals": "^17.5.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.3",
    "prettier-plugin-go-template": "^0.0.15",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typescript-eslint": "^8.58.2"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "assemblyai": "^4.30.0",
    "firebase-admin": "^13.8.0",
    "llm-chunk": "^0.0.1",
    "slugify": "^1.6.9",
    "zod": "^4.3.6"
  }
}
